# AgentIM backend environment
#
# Local development:
# - Use a GitHub OAuth App created for localhost / 127.0.0.1
# - Callback URL should be:
#   http://127.0.0.1:8900/api/auth/github/callback
#
# Production:
# - Use a separate GitHub OAuth App for the public domain
# - Do not reuse the local development OAuth credentials
# - Callback URL should be:
#   https://your-domain.example/api/auth/github/callback

AGENTIM_PORT=8900
AGENTIM_WEB_BASE_URL=http://127.0.0.1:3000
AGENTIM_SESSION_COOKIE_SECURE=false

# Local development OAuth app
GITHUB_CLIENT_ID=your_local_dev_client_id
GITHUB_CLIENT_SECRET=your_local_dev_client_secret

# Production reference only. Keep these in deployment secrets, not in this file.
# AGENTIM_WEB_BASE_URL=https://your-domain.example
# AGENTIM_SESSION_COOKIE_SECURE=true
# PROD_GITHUB_CLIENT_ID=your_production_client_id
# PROD_GITHUB_CLIENT_SECRET=your_production_client_secret
